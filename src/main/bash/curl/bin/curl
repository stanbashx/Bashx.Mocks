#!/usr/local/bin/bash

if [[ -n "${MOCKS_CURL_EXIT_CODE}" ]]; then
 if [[ "${MOCKS_CURL_EXIT_CODE}" =~ ^[1-9][0-9]*$ && ${MOCKS_CURL_EXIT_CODE} -lt 256 ]]; then
  exit ${MOCKS_CURL_EXIT_CODE}
 else
  echo 'Wrong exit code!' >&2; exit 1
 fi
fi

if [[ "${MOCKS_CURL_DST_FORMAT}" == '%{http_code}' ]]; then
 printf '%s' "${MOCKS_CURL_HTTP_CODE}"
elif [[ -z "${MOCKS_CURL_DST_FORMAT}" ]]; then
 printf '%s' "${MOCKS_CURL_DST}"
fi

echo 'Not implemented!'; exit 1 # todo
